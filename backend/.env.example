# Server Configuration
PORT=3000
HOST=localhost

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this
API_KEY=your-api-key-for-frontend-authentication

# CORS - Set to your Cloudflare Pages domain
ALLOWED_ORIGIN=https://your-proxy-domain.pages.dev

# Optional: Restrict to specific domains
BLOCKED_DOMAINS=localhost:3000,127.0.0.1,192.168.*
ALLOWED_DOMAINS=*

# Request timeout
PROXY_TIMEOUT=30000

# Rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
